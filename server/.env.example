# PhotoMap Server — Environment Variables
#
# LOCAL RUN INSTRUCTIONS:
#   1. Copy this file to .env and fill in the values.
#   2. MONGODB_URI: Create a free M0 cluster at https://www.mongodb.com/atlas
#      -> Database -> Connect -> Drivers -> copy the connection string.
#      Replace <username>, <password>, and set the database name (e.g. photomap).
#   3. cd server && npm run dev
#   4. cd client && npm run dev
#   5. Open http://localhost:5173

# MongoDB connection string (required — server refuses to start without this)
MONGODB_URI=

# Express server port (default: 3001)
PORT=3001

# Directory where uploaded photo files are stored on disk
STORAGE_PATH=./uploads

# Maximum file size per upload in bytes (default: 25 MB = 26214400)
MAX_FILE_BYTES=26214400

# Maximum number of files per batch upload (default: 50)
MAX_FILES_PER_BATCH=50
