# PhotoMap Server -- Environment Variables
#
# LOCAL RUN INSTRUCTIONS:
#   1. Copy this file to .env and fill in the values.
#   2. MONGODB_URI: Create a free M0 cluster at https://www.mongodb.com/atlas
#      -> Database -> Connect -> Drivers -> copy the connection string.
#      Replace <username>, <password>, and set the database name (e.g. photomap).
#   3. cd server && npm run dev
#   4. cd client && npm run dev
#   5. Open http://localhost:5173

# MongoDB connection string (required -- server refuses to start without this)
MONGODB_URI=

# Express server port (default: 3001)
PORT=3001

# Directory where uploaded photo files are stored on disk
STORAGE_PATH=./uploads

# Maximum file size per upload in bytes (default: 25 MB = 26214400)
MAX_FILE_BYTES=26214400

# Maximum number of files per batch upload (default: 50)
MAX_FILES_PER_BATCH=50

# ------------------------------------------------------------
# Phase 2: Auth (required -- server refuses to start without this)
# ------------------------------------------------------------

# JWT signing secret -- REQUIRED once Phase 2 is active
# Generate: openssl rand -hex 32
# Must be 32+ random characters. Keep this secret and out of version control.
JWT_SECRET=

# Node environment (development | production)
# Controls the cookie secure flag: secure=true only in production.
# On http://localhost leave as 'development' -- secure cookies are silently rejected on localhost.
NODE_ENV=development

# ------------------------------------------------------------
# Phase 2: Email (password reset -- optional in dev)
# ------------------------------------------------------------

# Resend API key -- get a free key at https://resend.com (3000 emails/month free)
# Leave blank to disable email sending (password reset will not deliver emails).
RESEND_API_KEY=

# From address for password-reset emails
# Use 'onboarding@resend.dev' for dev (no custom domain needed)
MAIL_FROM=onboarding@resend.dev

# App base URL -- used in password-reset email links
APP_URL=http://localhost:5173
